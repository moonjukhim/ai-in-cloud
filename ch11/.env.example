# Amazon Cognito Configuration

# User Pool
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx

# Cognito Hosted UI domain prefix (the part before .auth.{region}.amazoncognito.com)
# Example: if your domain is "myapp-demo.auth.us-east-1.amazoncognito.com",
# set COGNITO_DOMAIN_PREFIX=myapp-demo
COGNITO_DOMAIN_PREFIX=your-domain-prefix

# Resource Server identifier holding the three custom scopes
# Full scope strings become: ${COGNITO_RESOURCE_SERVER_ID}/${scope_name}
COGNITO_RESOURCE_SERVER_ID=agentcore

# Gateway App Client (Machine-to-Machine, client_credentials) -- Gateway -> MCP Server
COGNITO_GATEWAY_CLIENT_ID=
COGNITO_GATEWAY_CLIENT_SECRET=
COGNITO_MCP_SCOPE=agentcore/mcp:invoke

# Agent App Client (Machine-to-Machine, client_credentials) -- Agent -> Gateway
COGNITO_AGENT_CLIENT_ID=
COGNITO_AGENT_CLIENT_SECRET=
COGNITO_AGENT_SCOPE=agentcore/gateway:invoke

# User App Client (Authorization Code grant, public/confidential) -- User -> Agent
# Must have callback URL http://localhost:8080/callback registered
COGNITO_USER_CLIENT_ID=
COGNITO_USER_CLIENT_SECRET=
COGNITO_USER_SCOPE=agentcore/agent:invoke openid email profile

# Demo users for RBAC testing
# Create these users in Cognito, set permanent passwords, and assign to groups:
#   alice@example.com -> group: engineering-admin
#   bob@example.com   -> group: finance-viewer
COGNITO_USER_ALICE_EMAIL=alice@example.com
COGNITO_USER_BOB_EMAIL=bob@example.com
